# ==============================================================================
# Dr. AI CRM — Environment Configuration
# ==============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never share your .env file publicly or commit it to GitHub.
#            It contains passwords and API keys.
#
# ==============================================================================


# ── Database ─────────────────────────────────────────────────────────────────
# Where your CRM data is stored.
#   Local dev:   sqlite:///crm.db
#   Production:  Railway provides this automatically as a PostgreSQL URL
DATABASE_URL=sqlite:///crm.db


# ── Admin Login ──────────────────────────────────────────────────────────────
# Username and password to log into the CRM admin panel.
# Change these before deploying!
ADMIN_USER=admin
ADMIN_PASS=changeme


# ── Flask Secret Key ─────────────────────────────────────────────────────────
# Used to sign session cookies. Must be a random string in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string


# ── Flask Environment ────────────────────────────────────────────────────────
# "development" = debug mode + auto-reload
# "production"  = optimized for deployment
FLASK_ENV=development


# ── Business Branding ────────────────────────────────────────────────────────
# The name shown in the CRM header and throughout the app.
BUSINESS_NAME=My Business CRM


# ── Stripe (Payments) ───────────────────────────────────────────────────────
# Your Stripe Checkout URL for the sales/pricing page.
# Set to "#" to disable until you have a real link.
STRIPE_CHECKOUT_URL=https://buy.stripe.com/your-link


# ── Lead Magnet ──────────────────────────────────────────────────────────────
# URL for your free download / lead magnet on the landing page.
# Set to "#" to disable until you have a real link.
LEAD_MAGNET_URL=https://your-lead-magnet-download-link


# ── OpenRouter API Key (AI Chatbot) ─────────────────────────────────────────
# Powers the AI chatbot inside the CRM admin panel.
# Sign up at https://openrouter.ai to get your key.
# Cost: ~$0.01 per chatbot message
# Format: sk-or-v1-xxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-your-key-here


# ── Kie.ai API Key (Graphic Artist / Image Generation) ──────────────────────
# Powers the Graphic Artist Skill for generating website images, mockups,
# and branded graphics using the Nano Banana Pro model.
# Sign up at https://kie.ai to get your API key.
# Cost: ~$0.09 per image generated
# Format: Must include the "Bearer " prefix
KIE_AI_API_KEY=Bearer your-kie-ai-key-here
