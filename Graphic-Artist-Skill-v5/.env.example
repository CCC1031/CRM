# ── Book Image Toolkit — Required API Keys ──────────────────────────────────
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# ── Image Generation (required) ─────────────────────────────────────────────
# Sign up at https://kie.ai to get your API key
# Cost: ~$0.09 per image generated
# The "Bearer " prefix is required — include it
KIE_AI_API_KEY=Bearer your-kie-ai-key-here

# ── Document Analysis (optional) ────────────────────────────────────────────
# Only needed if you use the doc_analyzer.py workflow
# (auto-recommend where images should go in a PDF/DOCX)
# Sign up at https://openrouter.ai to get your API key
# Cost: ~$0.01 per analysis call
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
